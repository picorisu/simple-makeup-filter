{
  "manifest_version": 3,
  "name": "Simple Makeup Filter for Google Meet",
  "version": "1.0.0",
  "description": "美肌・メイク・シェーディングをカメラ映像に。全てローカル処理、映像は一切外部送信しません。",
  "permissions": ["storage"],
  "host_permissions": ["https://meet.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["defaults.js", "override.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["defaults.js", "bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/*", "vendor/wasm/*"],
      "matches": ["https://meet.google.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Beauty Filter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
