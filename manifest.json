{
  "manifest_version": 3,
  "name": "Meet Beauty Filter",
  "version": "1.0.0",
  "description": "Google Meet のカメラ映像にローカル処理の美肌フィルターをかける",
  "permissions": ["storage"],
  "host_permissions": ["https://meet.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["override.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/*", "vendor/wasm/*"],
      "matches": ["https://meet.google.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Beauty Filter"
  }
}
